<% if @matchweek %>
  <h1>Matchweek <%= @matchweek %></h1>

  <%= form_with url: predictions_path do %>
    <ul>
      <% @fixtures.each do |fixture| %>
        <% prediction = @predictions[fixture.id] %>
        <% locked = fixture.locked? %>
        <li>
          <span><%= fixture.kickoff_at.strftime("%a %-d %b, %H:%M") %></span>
          <span><%= fixture.home_team.name %></span>
          <% if locked %>
            <span><%= prediction ? "#{prediction.home_score}–#{prediction.away_score}" : "–" %></span>
          <% else %>
            <%= number_field_tag "predictions[#{fixture.id}][home_score]", prediction&.home_score, min: 0, max: 20 %>
            <span>–</span>
            <%= number_field_tag "predictions[#{fixture.id}][away_score]", prediction&.away_score, min: 0, max: 20 %>
          <% end %>
          <span><%= fixture.away_team.name %></span>
          <% if fixture.home_score %>
            <span><%= fixture.home_score %>–<%= fixture.away_score %></span>
          <% end %>
        </li>
      <% end %>
    </ul>

    <% if @fixtures.any? { |f| !f.locked? } %>
      <%= submit_tag "Save predictions" %>
    <% end %>
  <% end %>
<% else %>
  <h1>Matchday</h1>
  <p>No upcoming fixtures.</p>
<% end %>
